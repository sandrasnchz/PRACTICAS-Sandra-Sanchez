# Prepare SLURM submission script
scratch_dir=$(echo $PWD | sed "s|/data/ucct/bi/scratch_tmp|/scratch|")

# ND0013

cat <<EOF > sarek_ND0013.sbatch
#!/bin/bash
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=48G
#SBATCH --time=2-00:00:00
#SBATCH --partition=middle_idx
#SBATCH --output=sarek_ND0013_%j.log

export NXF_OPTS="-Xms2G -Xmx48G"

nextflow run /data/ucct/bi/pipelines/nf-core-sarek/nf-core-sarek-3.1.1/workflow/main.nf \
    -c /data/ucct/bi/research/20260204_TFM_SSANCHEZ_SM_SV_T/DOC/hpc_slurm_sarek.config \
    --input samplesheet_ND0013.csv \
    --outdir 01-sarek_ND0013 \
    --genome GATK.GRCh37 \
    --wes \
    --intervals /data/ucct/bi/research/20260204_TFM_SSANCHEZ_SM_SV_T/REFERENCES/MedExome_hg19_capture_plus50pb_targets.bed \
    --dbsnp /data/ucct/bi/references/eukaria/homo_sapiens/hg19/1000genomes_b37/variants/20131208/dbsnp_138_mod.b37.vcf.gz \
    --dbsnp_tbi /data/ucct/bi/references/eukaria/homo_sapiens/hg19/1000genomes_b37/variants/20131208/dbsnp_138_mod.b37.vcf.gz.tbi \
    --tools haplotypecaller \
    --joint_germline \
    --save_reference \
    --igenomes_ignore \
    --igenomes_base /data/ucct/bi/references/igenomes/ \
    -resume
EOF

echo "sbatch sarek_ND0013.sbatch" > _01_run_sarek_ND0013.sh

