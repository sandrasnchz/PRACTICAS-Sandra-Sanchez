# 01 - SAREK EXOME ANALYSIS

# Load required modules
module load Nextflow singularity

# Link input data
ln -s ../00-reads/ .
ln -s ../samples_id.txt .

# Create required directories
mkdir -p 02-postprocessing 03-annotation 99-stats

# Create samplesheet for nf-core/sarek

# ND0013
cat <<EOF > samplesheet_ND0013.csv
patient,sex,status,sample,lane,fastq_1,fastq_2
ND0013,XY,0,ND0013,1,00-reads/ND0013_R1.fastq.gz,00-reads/ND0013_R2.fastq.gz
EOF

# ND0323
